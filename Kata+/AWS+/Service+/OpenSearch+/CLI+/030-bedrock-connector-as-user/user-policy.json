{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "UseAwsCurl",
      "Effect": "Allow",
      "Action": "es:ESHttp*",
      "Resource": "arn:aws:es:us-east-1:121846058060:domain/domain33/*"
    },
    {
      "Sid": "CreateBedrockRole",
      "Effect": "Allow",
      "Action": [
        "iam:CreateRole",
        "iam:AttachRolePolicy",
        "iam:PassRole",
        "iam:DetachRolePolicy",
        "iam:DeleteRole"
      ],
      "Resource": "arn:aws:iam::121846058060:role/kata-role-bedrock-connector-as-root"
    }
  ]
}