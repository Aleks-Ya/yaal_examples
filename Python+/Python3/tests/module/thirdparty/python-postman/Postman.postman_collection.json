          "name": "Verify HTTP status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Status code is <300\", function () {",
                  "    pm.expect(pm.response.code).to.be.below(300);",
                  "});",
                  ""
