        {
          "name": "Verify response JSON body",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Extract a Text Field from JSON body\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.slideshow.title).to.eql(\"Sample Slide Show\")",
                  "});",
                  "",
                  "pm.test(\"Extract an Array Element from JSON body\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.slideshow.slides[0].title).to.eql(\"Wake up to WonderWidgets!\")",
                  "});",
                  "",
                  "pm.test(\"Check Array size in JSON body\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.slideshow.slides.length).to.eql(2)",
                  "});",
                  "",
                  "pm.test(\"Error field is null\", function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData.error).to.be.null",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
